generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessCategory {
  doctor
  hotel
}

enum TierPlan {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
}

model OnboardingSubmission {
  id               String           @id @default(cuid())
  businessName     String
  ownerName        String
  email            String
  phone            String
  city             String
  category         BusinessCategory
  tier             TierPlan
  kbFiles          Json
  integrationConfig Json
  provisionedNumber String
  dashboardUrl     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([email])
  @@index([tier])
  @@map("onboarding_submissions")
}
